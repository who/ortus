#!/usr/bin/env bash
# Fake claude shim for tests/test_plan.py.
# When invoked, parses its argv for a prompt, then materializes 3 bd issues
# inside the current working directory (which the wrapper sets to <repo>).
set -e

# We don't actually parse the prompt — for the tiny-3-task fixture, we
# hardcode 3 issues. Real claude would do the decomposition itself.

bd create --silent --title "Add CLI flag --dry-run" --type task --priority 2 \
    --description "Print what would happen without doing it." \
    --acceptance "Test: --dry-run produces no side effects." >/dev/null

bd create --silent --title "Write integration test for --dry-run" --type task --priority 2 \
    --description "Assert no side effects when --dry-run is passed." \
    --acceptance "Test passes." >/dev/null

bd create --silent --title "Document --dry-run in README" --type task --priority 3 \
    --description "Add a Flags section with examples." \
    --acceptance "README contains --dry-run example." >/dev/null

echo "fake-claude-plan: created 3 issues"
exit 0
