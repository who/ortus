{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(bd *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/credentials.json)"
    ],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "excludedCommands": ["bd", "bd *"],
    "network": {
      "allowLocalBinding": true,
      "allowManagedDomainsOnly": true,
      "allowedDomains": {{ (
        [
          "api.anthropic.com",
          "github.com",
          "api.github.com",
          "codeload.github.com",
          "raw.githubusercontent.com",
          "objects.githubusercontent.com"
        ]
        + (["registry.npmjs.org"] if project_type in ["typescript", "polyglot"] else [])
        + (["pypi.org", "files.pythonhosted.org"] if project_type in ["python", "polyglot"] else [])
        + (["crates.io", "static.crates.io"] if project_type in ["rust", "polyglot"] else [])
        + (["proxy.golang.org", "sum.golang.org"] if project_type in ["go", "polyglot"] else [])
      ) | tojson }}
    }
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [{"command": "bd prime", "type": "command"}],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [{"command": "bd prime", "type": "command"}],
        "matcher": ""
      }
    ]
  }
}
