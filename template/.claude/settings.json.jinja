{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "Bash(bd *)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(**/credentials.json)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowLocalBinding": true,
      "allowManagedDomainsOnly": true,
      "allowedDomains": {{ (
        [
          "api.anthropic.com",
          "github.com",
          "api.github.com",
          "codeload.github.com",
          "raw.githubusercontent.com",
          "objects.githubusercontent.com"
        ]
        + (["registry.npmjs.org"] if language_profile in ["javascript", "polyglot"] else [])
        + (["pypi.org", "files.pythonhosted.org"] if language_profile in ["python", "polyglot"] else [])
        + (["crates.io", "static.crates.io"] if language_profile in ["rust", "polyglot"] else [])
        + (["proxy.golang.org", "sum.golang.org"] if language_profile in ["go", "polyglot"] else [])
      ) | tojson }}
    }
  }
}
